{
  // Cloudflare Pages deployment — builds via nix
  // Deployed automatically via Cloudflare Git integration
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "web-app",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "build": {
    "command": "nix build .#cloudflare"
  }
}