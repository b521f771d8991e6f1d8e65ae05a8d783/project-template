{
  "name": "project-template",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "build": "expo export --platform web && esbuild src/server.ts --outfile=./dist/main.js --platform=node --bundle --minify",
    "build:server": "esbuild src/server.ts --outfile=./dist/main.js --platform=node --bundle --minify",
    "build:worker": "expo export --platform web && esbuild src/worker.ts --outfile=./dist/worker.js --platform=browser --bundle --minify --format=esm --external:node:*",
    "start": "expo start -c",
    "test": "jest",
    "lint": "expo lint",
    "prettier": "prettier . --write"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "prettier": {
    "useTabs": true,
    "semi": true,
    "singleQuote": false,
    "arrowParens": "always",
    "proseWrap": "always",
    "plugins": ["prettier-plugin-tailwindcss"]
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "29.5.14",
    "@types/morgan": "^1.9.10",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/react": "~19.1.0",
    "@typescript-eslint/parser": "^8.55.0",
    "babel-preset-expo": "~54.0.10",
    "compression": "^1.8.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.31.0",
    "expo": "~54.0.29",
    "expo-constants": "~18.0.12",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.10",
    "expo-localization": "^17.0.8",
    "expo-router": "~6.0.19",
    "expo-server": "~1.0.5",
    "expo-splash-screen": "~31.0.12",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "husky": "^9.1.7",
    "i18next": "^25.8.11",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.16",
    "morgan": "^1.10.1",
    "nativewind": "^4.2.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2",
    "wrangler": "^4.72.0"
  }
}
