{
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Dev Server (make dev)",
      "runtimeExecutable": "make",
      "runtimeArgs": [
        "dev"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder}/swift",
      "name": "Debug hello (swift)",
      "target": "hello",
      "configuration": "debug",
      "preLaunchTask": "swift: Build Debug hello (swift)"
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder}/swift",
      "name": "Release hello (swift)",
      "target": "hello",
      "configuration": "release",
      "preLaunchTask": "swift: Build Release hello (swift)"
    }
  ]
}