#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔨 Running nix flake check before commit..."

if ! nix flake check; then
  echo ""
  echo "❌ nix flake check failed — commit blocked"
  echo ""
  echo "Fix the errors and try again. To diagnose a specific target:"
  echo "  nix build .#native-lib       # C/C++/ObjC cmake library"
  echo "  nix build .#rust-lib         # Rust native library"
  echo "  nix build .#wasm-pkg         # Rust → WASM package"
  echo "  nix build .#swift-lib        # Swift library"
  echo "  nix build .#typescript-app   # TypeScript/Expo web app"
  echo "  nix build .#web-app          # Combined output"
  exit 1
fi

echo "✅ nix flake check passed — commit allowed"
